{
  "name": "@jakeave/star-system-seeder",
  "version": "0.17.1",
  "description": "Procedural solar system generator and renderer.",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./orrery-3d": "./src/orrery-3d/engine.ts",
    "./orrery-2d": "./src/orrery-2d/engine.ts"
  },
  "tasks": {
    "seed": "deno run --allow-write src/core/main.ts",
    "build": "deno run --allow-read --allow-write --allow-env --allow-run --allow-net build.ts",
    "renderer": "deno task build && deno run --allow-net --allow-read --allow-write --allow-run --allow-env server.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net",
    "check": "deno fmt --check && deno lint && deno check mod.ts server.ts build.ts build_test.ts src/",
    "pre-commit": "deno task check && deno task test",
    "pre-push": "deno task check && deno task test",
    "setup": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/pre-push"
  },
  "fmt": {
    "exclude": [
      "app/*.html",
      "app/*.bundle.js",
      "seeds",
      "bench",
      "docs",
      ".superpowers",
      ".claude"
    ]
  },
  "lint": {
    "exclude": [
      "app/*.bundle.js",
      "seeds",
      "bench",
      "docs",
      ".superpowers",
      ".claude"
    ]
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns"]
  },
  "publish": {
    "exclude": ["build_test.ts", "build.ts", "server.ts", "app/"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "esbuild": "npm:esbuild@0.23.1",
    "three": "npm:three@0.165.0"
  }
}
